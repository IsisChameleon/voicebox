      "fontSize": 14,
      "createdAt": "2026-05-20T05:00:06.031Z",
      "updatedAt": "2026-05-20T05:00:06.031Z",
      "version": 1
    },
    {
      "id": "mpdlf46xhvdic2dsil",
      "type": "text",
      "x": 440,
      "y": 520,
      "strokeColor": "#555",
