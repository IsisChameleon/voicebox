      "version": 1
    },
    {
      "id": "mpdlf46xwslbkn569rm",
      "type": "text",
      "x": 440,
      "y": 535,
      "strokeColor": "#555",
      "text": "server.py: speak() listen() start_call() stop()",
      "fontSize": 11,
      "createdAt": "2026-05-20T05:00:06.031Z",
      "updatedAt": "2026-05-20T05:00:06.031Z",
      "version": 1
    },
    {
      "id": "mpdlf46xfbsxkzppzde",
      "type": "text",
      "x": 440,
      "y": 555,
      "strokeColor": "#555",
      "text": "Owns the lifecycle of the Pipecat",
      "fontSize": 11,
      "createdAt": "2026-05-20T05:00:06.031Z",
      "updatedAt": "2026-05-20T05:00:06.031Z",
      "version": 1
    },
    {
      "id": "mpdlf46xjtn5cxwbk79",
      "type": "text",
      "x": 440,
      "y": 570,
      "strokeColor": "#555",
      "text": "child process. No audio code here.",
      "fontSize": 11,
      "createdAt": "2026-05-20T05:00:06.031Z",
      "updatedAt": "2026-05-20T05:00:06.031Z",
      "version": 1
    },
    {
