      "version": 1
    },
    {
      "id": "mpdlf46x11y1vzunkqk",
      "type": "text",
      "x": 100,
      "y": 495,
      "strokeColor": "#1e1e1e",
      "text": "Claude (host LLM)",
      "fontSize": 16,
      "createdAt": "2026-05-20T05:00:06.031Z",
      "updatedAt": "2026-05-20T05:00:06.031Z",
      "version": 1
    },
    {
      "id": "mpdlf46xsykw8ofnq7",
      "type": "text",
      "x": 100,
      "y": 520,
      "strokeColor": "#555",
      "text": "Decides when to call tools.",
      "fontSize": 11,
      "createdAt": "2026-05-20T05:00:06.031Z",
      "updatedAt": "2026-05-20T05:00:06.031Z",
      "version": 1
    },
    {
      "id": "mpdlf46xa4mzpd8tbq",
      "type": "text",
      "x": 100,
      "y": 535,
      "strokeColor": "#555",
      "text": "Has no microphone, no speaker.",
      "fontSize": 11,
      "createdAt": "2026-05-20T05:00:06.031Z",
      "updatedAt": "2026-05-20T05:00:06.031Z",
      "version": 1
    },
    {
      "id": "mpdlf46x9dle0ylyvsh",
      "type": "text",
      "x": 100,
      "y": 555,
      "strokeColor": "#555",
      "text": "Sees only the text returned by",
      "fontSize": 11,
      "createdAt": "2026-05-20T05:00:06.031Z",
      "updatedAt": "2026-05-20T05:00:06.031Z",
      "version": 1
    },
    {
      "id": "mpdlf46xs2459vjp2lb",
      "type": "text",
      "x": 100,
      "y": 570,
      "strokeColor": "#555",
      "text": "each tool call.",
      "fontSize": 11,
      "createdAt": "2026-05-20T05:00:06.031Z",
      "updatedAt": "2026-05-20T05:00:06.031Z",
      "version": 1
    },
    {
