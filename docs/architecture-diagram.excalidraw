      "fontSize": 14,
      "createdAt": "2026-05-20T05:00:06.031Z",
      "updatedAt": "2026-05-20T05:00:06.031Z",
      "version": 1
    },
    {
      "id": "mpdlf46xmgq78mhnbb",
      "type": "text",
      "x": 440,
      "y": 698,
      "strokeColor": "#555",
      "text": "bot.py command loop:",
      "fontSize": 11,
      "createdAt": "2026-05-20T05:00:06.031Z",
      "updatedAt": "2026-05-20T05:00:06.031Z",
      "version": 1
    },
    {
      "id": "mpdlf46xq0obto6300s",
      "type": "text",
      "x": 440,
      "y": 713,
      "strokeColor": "#555",
      "text": "  read cmd → act → write response",
      "fontSize": 11,
      "createdAt": "2026-05-20T05:00:06.031Z",
      "updatedAt": "2026-05-20T05:00:06.031Z",
      "version": 1
    },
    {
      "id": "mpdlf46xlkrkyyhhbq",
      "type": "text",
      "x": 440,
      "y": 733,
      "strokeColor": "#555",
